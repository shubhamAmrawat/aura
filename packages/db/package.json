{
  "name": "@aura/db",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx --env-file=../../.env src/seed.ts",
    "db:seed:hindusm": "tsx --env-file=../../.env src/seed-hindusm.ts",
    "db:migrate-r2": "tsx --env-file=../../.env src/migrate-to-r2.ts",
    "db:embeddings": "tsx --env-file=../../.env src/generate-embeddings.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.3.1",
    "drizzle-orm": "*",
    "openai": "^6.34.0",
    "postgres": "*",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "drizzle-kit": "*",
    "tsx": "^4.0.0",
    "typescript": "*"
  }
}