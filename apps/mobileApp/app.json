{
  "expo": {
    "name": "AURORA",
    "slug": "aurora-walls",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "aurora",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-media-library"
    ],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shubhzx09.aurorawalls"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.shubhzx09.aurorawalls",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "navigationBarColor": "#111111",
      "backgroundColor": "#111111"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "b42fe208-71d2-4443-8c22-8a6ddc63da11"
      }
    }
  }
}
